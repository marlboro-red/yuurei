// LANG_NEUTRAL(0), SUBLANG_NEUTRAL(0)
LANGUAGE 0, 0

#define RT_MANIFEST 1
RT_MANIFEST 24 "ghostty.manifest"

#define ID_ICON_GHOSTTY 1
ID_ICON_GHOSTTY ICON "ghostty.ico"

// Keep in sync with the release tag (yuurei's own versioning).
// "1" is VS_VERSION_INFO; the winres.h macro isn't available here.
1 VERSIONINFO
FILEVERSION     0,2,8,0
PRODUCTVERSION  0,2,8,0
FILEOS          0x40004L // VOS_NT_WINDOWS32
FILETYPE        0x1L // VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
        VALUE "FileDescription",    "yuurei - Ghostty for Windows"
        VALUE "FileVersion",        "0.2.8"
        VALUE "ProductVersion",     "0.2.8"
        VALUE "LegalCopyright",     "MIT; core (C) 2024 Mitchell Hashimoto, Ghostty contributors"
        VALUE "OriginalFilename",   "ghostty.exe"
        VALUE "ProductName",        "yuurei"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409,1200
    END
END
